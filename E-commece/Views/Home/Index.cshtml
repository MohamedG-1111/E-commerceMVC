@using E_commerce.Utility.Settings
@model IEnumerable<ProductListVm>

@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/css/home/index.css" rel="stylesheet" />

<!-- HERO -->
<section class="hero">
    <p class="hero-eyebrow">Our Collection</p>

    <h1>
        Every book you
        <br>
        could ever need.
    </h1>

    <p>
        Browse thousands of titles across every genre —
        from timeless classics to today's bestsellers.
    </p>

    <div class="hero-search">
        <input type="text"
               id="searchInput"
               placeholder="Search by title, author, or ISBN…" />

        <button type="button" onclick="filterBooks()">
            Search
        </button>
    </div>
</section>

<!-- FILTER BAR -->
<nav class="filter-bar" aria-label="Category filter">

    <span class="filter-label">Browse:</span>

    <button class="filter-chip active"
            onclick="setCategory(this,'')">
        All
    </button>

    @foreach (var cat in Model.Select(p => p.CategoryName)
                              .Distinct()
                              .OrderBy(c => c))
    {
        <button class="filter-chip"
                onclick="setCategory(this,'@cat')">
            @cat
        </button>
    }

</nav>

<!-- CATALOGUE -->
<main class="catalogue">

    <div class="catalogue-header">
        <h2>All Books</h2>
        <span id="count-label">@Model.Count() titles</span>
    </div>

    <div class="book-grid" id="bookGrid">
        <partial name="~/Views/Product/_BooksPartial.cshtml" model="Model" />
    </div>

    <div class="empty-state"
         id="emptyState"
         style="display:none;">
        <p>No books match your search.</p>
    </div>

</main>

@section Scripts
{
    <script>

        let activeCategory = '';
        let searchTerm = '';

        // Search while typing
        $("#searchInput").on("input", function() {

            searchTerm = $(this).val().trim();

            applyFilters();
        });

        // Search button
        function filterBooks() {
            searchTerm = $("#searchInput").val().trim();
            applyFilters();
        }

        // Category filter
        function setCategory(btn, category) {

            $(".filter-chip").removeClass("active");

            $(btn).addClass("active");

            activeCategory = category;

            applyFilters();
        }

        // Ajax Search + Category Filter
        function applyFilters() {

            $.ajax({
                url: '/Product/Search',
                type: 'GET',
                data: {
                    searchTerm: searchTerm,
                    category: activeCategory
                },
                success: function(result) {

                    $("#bookGrid").html(result);

                    let count = $("#bookGrid .book-card").length;

                    $("#count-label").text(count + " titles");

                    if (count === 0) {
                        $("#emptyState").show();
                    }
                    else {
                        $("#emptyState").hide();
                    }
                },
                error: function(xhr) {
                    console.log(xhr.responseText);
                }
            });
        }

    </script>
}