@using E_commerce.Utility.Settings
@using Ecommerce.Utility
@using Ecommerce.Utility.Pagination
@model PaginatedResult<ProductListVm>

<div class="row g-4">

    @foreach (var product in Model.Items)
    {
        <div class="col-xl-3 col-lg-3 col-md-6 col-sm-6">

            <article class="book-card"
                     data-title="@product.Title.ToLowerInvariant()"
                     data-author="@product.Author.ToLowerInvariant()"
                     data-isbn="@product.ISBN.ToLowerInvariant()"
                     data-category="@product.CategoryName">

                <div class="book-cover">

                    @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                    {
                        <img src="@($"{FileSettings.ImagesPathProducts}/{product.ImageUrl}")"
                             alt="@product.Title"
                             loading="lazy" />
                    }
                    else
                    {
                        <div class="book-cover-placeholder">
                            📖
                            <span>No cover</span>
                        </div>
                    }

                    <span class="category-badge">
                        @product.CategoryName
                    </span>

                </div>

                <div class="book-info">

                    <h3 class="book-title">
                        @product.Title
                    </h3>

                    <p class="book-author">
                        @product.Author
                    </p>

                    <p class="book-isbn">
                        @product.ISBN
                    </p>

                    <div class="book-footer">

                        <span class="book-price">
                            <sup>EGP</sup>@product.ListPrice.ToString("N0")
                        </span>

                        @if (User.IsInRole(Roles.Admin))
                        {
                            <a asp-controller="Product"
                               asp-action="Details"
                               asp-route-id="@product.Id"
                               class="btn-details">
                                View
                                <svg viewBox="0 0 24 24">
                                    <polyline points="9 18 15 12 9 6"></polyline>
                                </svg>
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Home"
                               asp-action="ProductDetails"
                               asp-route-id="@product.Id"
                               class="btn-details">
                                View
                                <svg viewBox="0 0 24 24">
                                    <polyline points="9 18 15 12 9 6"></polyline>
                                </svg>
                            </a>
                        }

                    </div>

                </div>

            </article>

        </div>
    }

</div>

<div class="mt-4 d-flex justify-content-center">
    <partial name="~/Views/Shared/_PaginationPagePartial.cshtml"
             model="Model" />
</div>