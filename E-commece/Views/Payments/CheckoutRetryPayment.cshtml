@using E_commerce.Utility.Settings
@model OrderPaymentVM

@{
    ViewData["Title"] = "Review Order";
}

<div class="container py-4">

    <h2 class="mb-4">Review Your Order</h2>

    <div class="alert alert-warning">
        <strong>Notice:</strong> Prices and discounts have been recalculated.
        Please review your order before continuing to payment.
    </div>

    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:90px;">Image</th>
                        <th>Product</th>
                        <th class="text-center">Price</th>
                        <th class="text-center">Quantity</th>
                        <th class="text-end">Total</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model.Items)
                    {
                        <tr>

                            <td>
                                <img asp-append-version="true"
                                     src="~/@($"{FileSettings.ImagesPathProducts}/{item.Image}")"
                                     alt="@item.ProductName"
                                     class="img-thumbnail"
                                     style="width:70px;height:70px;object-fit:cover;" />
                            </td>

                            <td>
                                @item.ProductName
                            </td>

                            <td class="text-center">
                                @item.Price.ToString("0.00") $
                            </td>

                            <td class="text-center">
                                @item.Count
                            </td>

                            <td class="text-end">
                                @((item.Price * item.Count).ToString("0.00")) $
                            </td>

                        </tr>
                    }

                </tbody>
            </table>

            <hr />

            <div class="row justify-content-end">

                <div class="col-md-4">

                    <table class="table">

                        <tr>
                            <th>Discount</th>
                            <td class="text-end text-success">
                                @Model.Discount.ToString("0.00") $
                            </td>
                        </tr>

                        <tr class="fw-bold fs-5">
                            <th>Total</th>
                            <td class="text-end">
                                @Model.OrderTotal.ToString("0.00") $
                            </td>
                        </tr>

                    </table>

                </div>

            </div>

            <form asp-action="PayRetryOrder"
                  asp-controller="Payments"
                  method="post"
                  class="text-end">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="orderId"
                       value="@Model.OrderId" />

                <a asp-controller="Order"
                   asp-action="MyOrders"
                   class="btn btn-outline-secondary">

                    Cancel
                </a>

                <button type="submit"
                        class="btn btn-success ms-2">

                    Pay Now
                </button>

            </form>

        </div>
    </div>

</div>