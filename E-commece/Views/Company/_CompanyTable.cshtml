@using Ecommerce.Utility.Pagination
@model PaginatedResult<CompanyVM>

@if (Model != null && Model.Items.Any())
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">

            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>City</th>
                    <th>Email</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="fw-semibold">@item.Name</td>
                        <td>@item.City</td>
                        <td>@item.Email</td>

                        <td class="text-center">

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-info btn-sm">
                                <i class="bi bi-eye"></i>
                                Details
                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               asp-route-returnUrl="@Url.Action("Index","Company",new {
                                     PageSize=Model.PageSize,
                                     PageNumber=Model.PageNumber

                                    })"
                               class="btn btn-warning btn-sm">
                                <i class="bi bi-pencil-square"></i>
                                Edit
                            </a>

                            <button class="btn btn-danger btn-sm"
                                    onclick="openDeleteModal('@item.Name',
                                '@Url.Action("Delete", "Company", new { id = item.Id })')">
                                <i class="bi bi-trash"></i>
                                Delete
                            </button>

                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>
}
else
{
    <div class="alert alert-info text-center">
        No companies found.
    </div>
}

<!-- Delete Modal -->
<div id="deleteOverlay"
     onclick="handleOverlayClick(event)"
     style="display:none;
    position:fixed;
    inset:0;
    background:rgba(0,0,0,.5);
    z-index:1050;
    align-items:center;
    justify-content:center;">

    <div class="bg-white shadow rounded p-4"
         style="max-width:420px;width:90%;">

        <div class="text-center">

            <div class="mb-3">
                <i class="bi bi-trash-fill text-danger"
                   style="font-size:3rem;"></i>
            </div>

            <h4 class="fw-bold">
                Delete Company
            </h4>

            <p class="text-muted mt-3">
                Are you sure you want to delete
                <strong id="companyName"></strong>?
            </p>

            <p class="text-danger small">
                This action cannot be undone.
            </p>

        </div>

        <div class="d-flex justify-content-center gap-2 mt-4">

            <button type="button"
                    class="btn btn-secondary"
                    onclick="closeDeleteModal()">
                Cancel
            </button>

            <a id="confirmDeleteBtn"
               href="#"
               class="btn btn-danger">
                <i class="bi bi-trash"></i>
                Delete
            </a>

        </div>

    </div>

</div>

<partial name="~/Views/Shared/_PaginationPagePartial.cshtml"
         model="Model" />
<script>

    function openDeleteModal(name, url) {
        document.getElementById("companyName").textContent = '"' + name + '"';
        document.getElementById("confirmDeleteBtn").href = url;

        document.getElementById("deleteOverlay").style.display = "flex";
    }

    function closeDeleteModal() {
        document.getElementById("deleteOverlay").style.display = "none";
    }

    function handleOverlayClick(e) {
        if (e.target === document.getElementById("deleteOverlay")) {
            closeDeleteModal();
        }
    }

    document.addEventListener("keydown", function(e) {
        if (e.key === "Escape") {
            closeDeleteModal();
        }
    });

</script>