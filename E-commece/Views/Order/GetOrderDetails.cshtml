@using E_commerce.Utility.Settings
@model E_commerce.BLL.ViewModels.OrderDetailsVM

@{
    ViewData["Title"] = "Order Details";
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">
            <i class="bi bi-receipt"></i> Order #@Model.Id
        </h2>

        <a asp-action="AllOrders" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Orders
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Order Information</h5>
        </div>

        <div class="card-body">

            <div class="row g-4">

                <div class="col-md-3">
                    <div class="border rounded p-3 h-100">
                        <small class="text-muted">Order Date</small>
                        <h6 class="mt-2">@Model.OrderDate.ToString("dd MMM yyyy")</h6>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="border rounded p-3 h-100">
                        <small class="text-muted">Order Status</small>
                        <h6 class="mt-2">
                            <span class="badge bg-primary">
                                @Model.OrderStatus
                            </span>
                        </h6>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="border rounded p-3 h-100">
                        <small class="text-muted">Payment Status</small>
                        <h6 class="mt-2">
                            <span class="badge bg-success">
                                @Model.PaymentStatus
                            </span>
                        </h6>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="border rounded p-3 h-100">
                        <small class="text-muted">Total</small>
                        <h4 class="text-success mt-2">
                            $@Model.OrderTotal.ToString("0.00")
                        </h4>
                    </div>
                </div>

            </div>

        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Carrier) || !string.IsNullOrEmpty(Model.TrackingNumber))
    {
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white">
                <h5 class="mb-0">
                    <i class="bi bi-truck text-primary"></i>
                    Shipping Information
                </h5>
            </div>

            <div class="card-body">

                <div class="row g-4">

                    @if (!string.IsNullOrEmpty(Model.Carrier))
                    {
                        <div class="col-md-6">
                            <div class="border rounded p-3 h-100">
                                <small class="text-muted">Shipping Company</small>
                                <h6 class="mt-2">@Model.Carrier</h6>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.TrackingNumber))
                    {
                        <div class="col-md-6">
                            <div class="border rounded p-3 h-100">
                                <small class="text-muted">Tracking Number</small>
                                <h6 class="mt-2">@Model.TrackingNumber</h6>
                            </div>
                        </div>
                    }

                </div>

            </div>
        </div>
    }

    <div class="card shadow-sm border-0">

        <div class="card-header bg-white">
            <h5 class="mb-0">
                Products
            </h5>
        </div>

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th style="width:90px;">Image</th>
                        <th>Product</th>
                        <th class="text-center">Quantity</th>
                        <th class="text-end">Price</th>
                        <th class="text-end">Subtotal</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model.Items)
                    {
                        <tr>

                            <td>
                                <img asp-append-version="true"
                                     src="~/@($"{FileSettings.ImagesPathProducts}/{item.Image}")"
                                     alt="@item.ProductName"
                                     class="img-fluid rounded shadow-sm border"
                                     style="width:70px;height:70px;object-fit:cover;" />
                            </td>

                            <td>
                                <h6 class="mb-0">@item.ProductName</h6>
                            </td>

                            <td class="text-center">
                                @item.Count
                            </td>

                            <td class="text-end">
                                $@item.Price.ToString("0.00")
                            </td>

                            <td class="text-end fw-bold">
                                $@((item.Price * item.Count).ToString("0.00"))
                            </td>

                        </tr>
                    }

                </tbody>

                <tfoot class="table-light">
                    <tr>
                        <th colspan="4" class="text-end fs-5">
                            Grand Total
                        </th>

                        <th class="text-end text-success fs-4">
                            $@Model.OrderTotal.ToString("0.00")
                        </th>
                    </tr>
                </tfoot>

            </table>

        </div>

    </div>

</div>
