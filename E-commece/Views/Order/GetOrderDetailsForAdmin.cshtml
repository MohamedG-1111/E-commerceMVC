@using E_commerce.DAL.Entities.enums
@model OrderDetailsForAdminVM

@{
    ViewData["Title"] = $"Order #{Model.OrderId}";
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">

        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-receipt text-primary"></i>
                Order #@Model.OrderId
            </h2>

            <p class="text-muted mb-0">
                Review customer information, payment details, shipping information,
                and manage the order status.
            </p>
        </div>

        <div class="d-flex align-items-center gap-2">

            @switch (Model.OrderStatus)
            {
                case OrderStatus.Pending:
                    <span class="badge fs-6 px-3 py-2 rounded-pill"
                          style="background-color:#fff3cd;color:#8a6d00;">
                        Pending
                    </span>
                    break;

                case OrderStatus.Approved:
                    <span class="badge fs-6 px-3 py-2 rounded-pill"
                          style="background-color:#cfe2ff;color:#084298;">
                        Approved
                    </span>
                    break;

                case OrderStatus.Processing:
                    <span class="badge fs-6 px-3 py-2 rounded-pill"
                          style="background-color:#cff4fc;color:#055160;">
                        Processing
                    </span>
                    break;

                case OrderStatus.Shipped:
                    <span class="badge fs-6 px-3 py-2 rounded-pill"
                          style="background-color:#e2d9f3;color:#4b2e83;">
                        Shipped
                    </span>
                    break;

                case OrderStatus.Delivered:
                    <span class="badge fs-6 px-3 py-2 rounded-pill"
                          style="background-color:#d1e7dd;color:#0f5132;">
                        Delivered
                    </span>
                    break;

                case OrderStatus.Cancelled:
                    <span class="badge fs-6 px-3 py-2 rounded-pill"
                          style="background-color:#f8d7da;color:#842029;">
                        Cancelled
                    </span>
                    break;
            }
            <a asp-action="AllOrders" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i>
                Back to Orders
            </a>

        </div>

    </div>

    <div class="row g-3">

        <!-- Customer Information -->
        <div class="col-lg-4">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-header bg-white fw-bold border-bottom">
                    <i class="bi bi-person-circle text-primary me-1"></i>
                    Customer Information
                </div>

                <div class="card-body">

                    <div class="mb-3">
                        <label class="form-label small text-muted mb-1">Full Name</label>
                        <input class="form-control bg-light" value="@Model.UserName" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small text-muted mb-1">Email</label>
                        <input class="form-control bg-light" value="@Model.UserEmail" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small text-muted mb-1">Phone</label>
                        <input class="form-control bg-light" value="@Model.Phone" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small text-muted mb-1">Address</label>
                        <textarea class="form-control bg-light" rows="3" readonly>@Model.Address</textarea>
                    </div>

                    <div>
                        <label class="form-label small text-muted mb-1">Postal Code</label>
                        <input class="form-control bg-light" value="@Model.PostalCode" readonly />
                    </div>

                </div>

            </div>

        </div>

        <!-- Order Details -->
        <div class="col-lg-8">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-header bg-white fw-bold border-bottom">
                    <i class="bi bi-box-seam text-primary me-1"></i>
                    Order Details
                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Order Total</label>
                            <input class="form-control bg-light"
                                   value="@Model.OrderTotal.ToString("0.00") EGP"
                                   readonly />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Payment Status</label>
                            <input class="form-control bg-light"
                                   value="@Model.PaymentStatus"
                                   readonly />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Payment Date</label>
                            <input class="form-control bg-light"
                                   value="@(Model.PaymentDate?.ToString("dd/MM/yyyy") ?? "-")"
                                   readonly />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Payment Intent</label>
                            <input class="form-control bg-light"
                                   value="@Model.PaymentIntentId"
                                   readonly />
                        </div>

                    </div>

                    <hr />

                        <form asp-action="UpdateStatus" method="post">

                            @Html.AntiForgeryToken()

                            <input type="hidden" name="Id" value="@Model.OrderId" />

                            @if (Model.OrderStatus == OrderStatus.Approved)
                            {
                                <button type="submit"
                                        name="OrderStatus"
                                        value="@OrderStatus.Processing"
                                        class="btn btn-primary">
                                    <i class="bi bi-gear"></i>
                                    Move to Processing
                                </button>
                            }
                            else if (Model.OrderStatus == OrderStatus.Processing)
                            {
                                <button type="button"
                                        id="showShippingForm"
                                        class="btn btn-info text-white">
                                    <i class="bi bi-truck"></i>
                                    Ship Order
                                </button>

                                <div id="shippingForm" class="card mt-3 border-0 bg-light shadow-sm d-none">

                                    <div class="card-body">

                                        <h6 class="fw-bold mb-3">Shipping Information</h6>

                                        <div class="row">

                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Shipping Company</label>
                                                <input asp-for="Carrier"
                                                       class="form-control"
                                                       placeholder="DHL, Aramex..." />
                                            </div>

                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">Tracking Number</label>
                                                <input asp-for="TrackingNumber"
                                                       class="form-control"
                                                       placeholder="Tracking Number" />
                                            </div>

                                        </div>

                                        <div class="d-flex gap-2">

                                            <button type="submit"
                                                    name="OrderStatus"
                                                    value="@OrderStatus.Shipped"
                                                    class="btn btn-success">
                                                <i class="bi bi-check-circle"></i>
                                                Confirm Shipment
                                            </button>

                                            <button type="button" id="cancelShipping" class="btn btn-outline-secondary">
                                                Cancel
                                            </button>

                                        </div>

                                    </div>

                                </div>
                            }
                            else if (Model.OrderStatus == OrderStatus.Shipped)
                            {
                                <button type="submit"
                                        name="OrderStatus"
                                        value="@OrderStatus.Delivered"
                                        class="btn btn-success">
                                    <i class="bi bi-check-circle"></i>
                                    Mark as Delivered
                                </button>

                                <div class="alert alert-light border mt-3 mb-0">
                                    <strong>Shipping Company:</strong> @Model.Carrier
                                    <br />
                                    <strong>Tracking Number:</strong> @Model.TrackingNumber
                                </div>
                            }

                            @if (Model.OrderStatus == OrderStatus.Delivered &&
                                 Model.PaymentStatus == PaymentStatus.ApprovedForDelayedPayment)
                            {
                                <button type="submit"
                                        name="PaymentStatus"
                                        value="@PaymentStatus.Paid"
                                        class="btn btn-warning">
                                    <i class="bi bi-credit-card"></i>
                                    Pay Now
                                </button>
                            }

                        </form>


                 

                </div>

            </div>

        </div>

    </div>

    <!-- Order Items -->
    <div class="card shadow-sm border-0 mt-4">

        <div class="card-header bg-white fw-bold border-bottom d-flex justify-content-between align-items-center">
            <span>
                <i class="bi bi-cart3 text-primary me-1"></i>
                Order Items
            </span>
            <span class="badge bg-light text-dark border">
                @Model.OrderDetails.Count() item(s)
            </span>
        </div>

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th class="text-center">Price</th>
                        <th class="text-center">Quantity</th>
                        <th class="text-center">Subtotal</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.OrderDetails)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td class="text-center">@item.Price.ToString("0.00") EGP</td>
                            <td class="text-center">@item.Count</td>
                            <td class="text-center fw-bold">@((item.Price * item.Count).ToString("0.00")) EGP</td>
                        </tr>
                    }
                </tbody>

                <tfoot class="table-light">
                    <tr>
                        <th colspan="3" class="text-end">Grand Total</th>
                        <th class="text-center text-success">@Model.OrderTotal.ToString("0.00") EGP</th>
                    </tr>
                </tfoot>

            </table>

        </div>

    </div>

</div>

@section Scripts
{
    <script>

        document.addEventListener("DOMContentLoaded", function() {

            const showBtn = document.getElementById("showShippingForm");
            const shippingForm = document.getElementById("shippingForm");
            const cancelBtn = document.getElementById("cancelShipping");

            if (showBtn) {
                showBtn.addEventListener("click", function() {
                    shippingForm.classList.remove("d-none");
                    showBtn.classList.add("d-none");
                });
            }

            if (cancelBtn) {
                cancelBtn.addEventListener("click", function() {
                    shippingForm.classList.add("d-none");
                    showBtn.classList.remove("d-none");
                });
            }

        });

    </script>
}
