@using Ecommerce.Utility

<header>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark px-3">
        <div class="container">

            <!-- Brand -->
            <a class="navbar-brand fw-bold"
               asp-controller="Home"
               asp-action="Index">
                <i class="bi bi-bag-heart-fill text-warning me-1"></i>
                E-Commerce
            </a>

            <!-- Toggle -->
            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">

                <!-- ================= LEFT ================= -->
                <ul class="navbar-nav me-auto">

                    <!-- Guest Links -->
                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Home"
                           asp-action="Index">
                            <i class="bi bi-house-door me-1"></i>
                            Home
                        </a>
                    </li>


                    @if (!User.IsInRole(Roles.Admin))
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Contact">
                                <i class="bi bi-envelope me-1"></i>
                                Contact
                            </a>
                        </li>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @* ================= Admin ================= *@
                        @if (User.IsInRole(Roles.Admin))
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Category"
                                   asp-action="Index">
                                    <i class="bi bi-tags me-1"></i>
                                    Categories
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Company"
                                   asp-action="Index">
                                    <i class="bi bi-buildings me-1"></i>
                                    Companies
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Account"
                                   asp-action="Index">
                                    <i class="bi bi-people me-1"></i>
                                    Accounts
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Order"
                                   asp-action="ManageOrders">
                                    <i class="bi bi-clipboard-check me-1"></i>
                                    Manage Orders
                                </a>
                            </li>
                        }
                        else
                        {
                            @* Customer / Company / Employee *@

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Order"
                                   asp-action="MyOrders">
                                    <i class="bi bi-receipt me-1"></i>
                                    My Orders
                                </a>
                            </li>

                            @if (User.IsInRole(Roles.Employee))
                            {
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Order"
                                       asp-action="ManageOrders">
                                        <i class="bi bi-clipboard-check me-1"></i>
                                        Manage Orders
                                    </a>
                                </li>
                            }
                        }
                    }

                </ul>

                <!-- ================= RIGHT ================= -->
                <div class="d-flex align-items-center gap-2">

                    @if (User.Identity?.IsAuthenticated == true &&
                        !User.IsInRole(Roles.Admin))
                    {
                        <div class="position-relative">
                            <a asp-controller="Cart"
                               asp-action="Index"
                               class="btn btn-outline-light">
                                <i class="bi bi-cart3"></i>
                            </a>

                            @await Component.InvokeAsync("CartCount")
                        </div>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @await Component.InvokeAsync("UserDropdown")
                    }
                    else
                    {
                        <a asp-controller="Auth"
                           asp-action="Login"
                           class="btn btn-warning btn-sm fw-semibold">
                            Login
                        </a>

                        <a asp-controller="Auth"
                           asp-action="Register"
                           class="btn btn-outline-warning btn-sm fw-semibold">
                            Register
                        </a>
                    }

                </div>

            </div>
        </div>
    </nav>
</header>