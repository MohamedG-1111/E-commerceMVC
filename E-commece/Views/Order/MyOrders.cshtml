@model IEnumerable<E_commerce.BLL.ViewModels.OrderVM>

@{
    ViewData["Title"] = "My Orders";
}

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">My Orders</h2>
            <p class="text-muted small mb-0">Manage and track your recent purchase history.</p>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="card border-0 shadow-sm text-center p-5">
            <div class="card-body">
                <div class="mb-3">
                    <i class="bi bi-receipt-cutoff text-muted display-3"></i>
                </div>
                <h4 class="fw-semibold text-secondary">No Orders Found</h4>
                <p class="text-muted mb-4">You haven't placed any orders with us yet.</p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">Start Shopping</a>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-uppercase fs-7 fw-bold text-muted">
                        <tr>
                            <th class="ps-4" style="width: 12%;">Order ID</th>
                            <th style="width: 15%;">Date</th>
                            <th style="width: 15%;">Status</th>
                            <th style="width: 15%;">Payment</th>
                            <th class="text-center" style="width: 10%;">Items</th>
                            <th style="width: 15%;">Total</th>
                            <th class="text-end pe-4" style="width: 18%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-dark">
                                    #@order.Id
                                </td>

                                <td class="text-secondary">
                                    @order.OrderDate.ToString("MMM dd, yyyy")
                                </td>

                                <td>
                                    @{
                                        var statusClass = order.OrderStatus?.ToString().ToLower() switch
                                        {
                                            "pending" => "bg-warning-subtle text-warning-emphasis",
                                            "processing" => "bg-info-subtle text-info-emphasis",
                                            "shipped" => "bg-primary-subtle text-primary-emphasis",
                                            "completed" => "bg-success-subtle text-success-emphasis",
                                            "cancelled" => "bg-danger-subtle text-danger-emphasis",
                                            _ => "bg-secondary-subtle text-secondary-emphasis"
                                        };
                                    }
                                    <span class="badge rounded-pill px-2.5 py-1.5 fw-medium @statusClass">
                                        @order.OrderStatus
                                    </span>
                                </td>

                                <td>
                                    @{
                                        var paymentClass = order.PaymentStatus?.ToString().ToLower() switch
                                        {
                                            "paid" => "bg-success-subtle text-success-emphasis",
                                            "pending" => "bg-warning-subtle text-warning-emphasis",
                                            "failed" => "bg-danger-subtle text-danger-emphasis",
                                            _ => "bg-secondary-subtle text-secondary-emphasis"
                                        };
                                    }
                                    <span class="badge rounded-pill px-2.5 py-1.5 fw-medium @paymentClass">
                                        @order.PaymentStatus
                                    </span>
                                </td>

                                <td class="text-center text-secondary">
                                    @order.ItemsCount
                                </td>

                                <td class="fw-bold text-dark">
                                    @order.OrderTotal  <span class="fs-7 fw-normal text-muted">$</span>
                                </td>

                                <td class="text-end pe-4">
                                    <a asp-controller="Order"
                                       asp-action="GetOrderDetails"
                                       asp-route-orderId="@order.Id"
                                       class="btn btn-sm btn-outline-dark px-3 fw-medium">
                                        View Details
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* Optional: Inline styling helper for smaller font sizes if not custom defined in your CSS *@
<style>
    .fs-7 {
        font-size: 0.8rem;
    }

    .py-1.5 {
        padding-top: 0.35rem !important;
        padding-bottom: 0.35rem !important;
    }

    .px-2.5 {
        padding-left: 0.65rem !important;
        padding-right: 0.65rem !important;
    }
</style>