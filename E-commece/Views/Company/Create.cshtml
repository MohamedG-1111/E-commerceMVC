@model E_commerce.BLL.ViewModels.CompanyInfoVM

@{
    ViewData["Title"] = "Create Company";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="~/css/company/create.css" rel="stylesheet" />

<div class="container py-5">
    <div class="card shadow-sm border-0">

        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Create New Company</h4>
        </div>

        <div class="card-body p-4">

            <form asp-action="Create" asp-controller="Company" method="post">

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" placeholder="Company name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control" placeholder="company@email.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="City" class="form-label fw-semibold"></label>
                        <input asp-for="City" class="form-control" placeholder="City" />
                        <span asp-validation-for="City" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="PostalCode" class="form-label fw-semibold"></label>
                        <input asp-for="PostalCode" class="form-control" placeholder="Postal Code" />
                        <span asp-validation-for="PostalCode" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Address" class="form-label fw-semibold"></label>
                    <input asp-for="Address" class="form-control" placeholder="Full address" />
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Phone" class="form-label fw-semibold"></label>
                    <input asp-for="Phone" class="form-control" placeholder="01000000000" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>


                <div class="mb-4">
                    <label asp-for="DiscountPercentage" class="form-label fw-semibold"></label>

                    <div class="input-group">
                        <input asp-for="DiscountPercentage" class="form-control" placeholder="0 - 100" />
                        <span class="input-group-text">%</span>
                    </div>

                    <span asp-validation-for="DiscountPercentage" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-secondary">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-success">
                        Create
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}