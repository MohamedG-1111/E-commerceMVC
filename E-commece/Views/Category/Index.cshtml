@using DataAcessLayer.Models
@model IEnumerable<Category>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Categories</h4>
    <a asp-controller="Category" asp-action="Create" class="btn btn-primary btn-sm">+ New Category</a>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No categories found.</div>
}
else
{
    <div class="card">
        <div class="card-body">
            <table class="table table-bordered table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Category Name</th>
                        <th class="text-center">Display Order</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in Model)
                    {
                        <tr>
                            <td>@category.Name</td>
                            <td class="text-center">@category.DisplayOrder</td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@category.Id" class="btn btn-sm btn-primary">Show</a>
                                <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-warning">Edit</a>
                                <button class="btn btn-sm btn-danger"
                                        onclick="openDeleteModal('@category.Name', '@Url.Action("ConfirmDelete", "Category", new { id = category.Id })')">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Delete Confirmation Modal -->
<div id="deleteOverlay" onclick="handleOverlayClick(event)"
     style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:1050; align-items:center; justify-content:center;">
    <div style="background:#fff; border-radius:12px; padding:2rem; max-width:380px; width:90%; text-align:center;">
        <div style="font-size:2.5rem; color:#dc3545; margin-bottom:1rem;">
            <i class="bi bi-trash"></i>
        </div>
        <h5 style="font-weight:600; margin-bottom:.5rem;">Confirm Delete</h5>
        <p style="color:#6c757d; font-size:.9rem; margin-bottom:1.5rem;">
            Are you sure you want to delete <strong id="categoryName"></strong>?<br>
            This action cannot be undone.
        </p>
        <div style="display:flex; gap:10px; justify-content:center;">
            <button class="btn btn-secondary btn-sm" onclick="closeDeleteModal()">Cancel</button>
            <a id="confirmDeleteBtn" href="#" class="btn btn-danger btn-sm">Delete</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openDeleteModal(name, url) {
            document.getElementById('categoryName').textContent = '"' + name + '"';
            document.getElementById('confirmDeleteBtn').href = url;
            document.getElementById('deleteOverlay').style.display = 'flex';
        }

        function closeDeleteModal() {
            document.getElementById('deleteOverlay').style.display = 'none';
        }

        function handleOverlayClick(e) {
            if (e.target === document.getElementById('deleteOverlay')) closeDeleteModal();
        }

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeDeleteModal();
        });
    </script>
}