@model LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="~/css/account/login.css" rel="stylesheet" />
<style>
    /* login.css */
    body {
        background: #f5f7fa;
    }

    .login-card {
        max-width: 480px;
        margin: auto;
        border: none;
        border-radius: 15px;
    }

    .login-header {
        background: linear-gradient(135deg, #1a252f 0%, #2c3e50 100%);
        color: white;
        text-align: center;
        padding: 24px;
    }

    .form-control {
        border-radius: 10px;
    }

        .form-control:focus {
            border-color: #2c3e50;
            box-shadow: 0 0 0 0.25rem rgba(44, 62, 80, 0.15);
        }

    .btn-login {
        background: #1a252f;
        color: white;
        border: none;
        border-radius: 10px;
        padding: 12px;
        font-weight: 600;
        transition: background 0.2s ease;
    }

        .btn-login:hover {
            background: #2c3e50;
            color: white;
    }</style>
<div class="container py-5">
    <div class="card login-card shadow">

        <div class="login-header rounded-top-3">
            <h3 class="mb-1 fw-bold">WELCOME BACK</h3>
            <p class="mb-0 text-white-50">Please sign in to your account</p>
        </div>

        <div class="card-body p-4 p-md-5">
            <form asp-action="Login" asp-controller="Auth"
                  asp-route-returnUrl="@ViewData["ReturnUrl"]"
                  method="post" novalidate>

                <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                    <input asp-for="Email" class="form-control" placeholder="example@mail.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label fw-semibold">Password</label>
                    <div class="input-group">
                        <input asp-for="Password" type="password" id="password"
                               class="form-control" placeholder="••••••••" />
                        <button type="button" class="btn btn-outline-secondary"
                                onclick="togglePassword('password', this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">Remember Me</label>
                    </div>
                    <a asp-action="ForgotPassword" asp-controller="Account"
                       class="text-decoration-none small fw-semibold" style="color: #2c3e50;">
                        Forgot Password?
                    </a>
                </div>

                <button type="submit" class="btn btn-login w-100 fs-5 shadow-sm">
                    Sign In
                </button>

                <div class="text-center mt-4">
                    <span class="text-muted small">Don't have an account?</span>
                    <a asp-action="Register" asp-controller="Auth"
                       class="text-decoration-none small fw-semibold ms-1" style="color: #2c3e50;">
                        Create one
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(id, btn) {
            var input = document.getElementById(id);
            var icon = btn.querySelector("i");
            if (input.type === "password") {
                input.type = "text";
                icon.className = "bi bi-eye-slash";
            } else {
                input.type = "password";
                icon.className = "bi bi-eye";
            }
        }
    </script>
}