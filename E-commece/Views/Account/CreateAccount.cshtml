@using Ecommerce.Utility
@model AccountVM

@{
    ViewData["Title"] = "Create Account";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="container py-5">

    <div class="card shadow border-0 rounded-4 overflow-hidden">

        <!-- Header -->
        <div class="bg-primary text-white text-center py-4">
            <h3 class="fw-bold mb-1">
                CREATE NEW ACCOUNT
            </h3>
            <p class="mb-0 text-white-50">
                Fill in the account information below
            </p>
        </div>

        <div class="card-body p-4 p-md-5">

            <form asp-action="CreateAccount"
                  method="post"
                  enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="All"
                     class="text-danger mb-3 fw-semibold"></div>

                <!-- Profile Picture -->
                <div class="text-center mb-4">

                    <input asp-for="ProfilePicture"
                           type="file"
                           id="profileImgInput"
                           accept="image/*"
                           hidden />

                    <div class="avatar-wrapper">

                        <div class="avatar"
                             onclick="document.getElementById('profileImgInput').click()">

                            <div id="defaultAvatarIcon"
                                 class="avatar-default-icon">
                                <i class="bi bi-person-circle"></i>
                            </div>

                            <img id="imagePreview"
                                 style="display:none;" />
                        </div>

                    </div>

                    <small id="uploadHintText"
                           class="text-muted d-block mt-2">
                        Click image to upload
                    </small>

                    <span asp-validation-for="ProfilePicture"
                          class="text-danger small"></span>

                </div>

                <div class="row">

                    <!-- First Name -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="FirstName"
                               class="form-label fw-semibold"></label>

                        <input asp-for="FirstName"
                               class="form-control" />

                        <span asp-validation-for="FirstName"
                              class="text-danger small"></span>
                    </div>

                    <!-- Last Name -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="LastName"
                               class="form-label fw-semibold"></label>

                        <input asp-for="LastName"
                               class="form-control" />

                        <span asp-validation-for="LastName"
                              class="text-danger small"></span>
                    </div>

                    <!-- Email -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email"
                               class="form-label fw-semibold"></label>

                        <input asp-for="Email"
                               class="form-control" />

                        <span asp-validation-for="Email"
                              class="text-danger small"></span>
                    </div>

                    <!-- Phone -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone"
                               class="form-label fw-semibold"></label>

                        <input asp-for="Phone"
                               class="form-control" />

                        <span asp-validation-for="Phone"
                              class="text-danger small"></span>
                    </div>

                    <!-- Address -->
                    <div class="col-md-12 mb-3">
                        <label asp-for="StreetAddress"
                               class="form-label fw-semibold"></label>

                        <input asp-for="StreetAddress"
                               class="form-control" />

                        <span asp-validation-for="StreetAddress"
                              class="text-danger small"></span>
                    </div>

                    <!-- City -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="City"
                               class="form-label fw-semibold"></label>

                        <input asp-for="City"
                               class="form-control" />

                        <span asp-validation-for="City"
                              class="text-danger small"></span>
                    </div>

                    <!-- Postal -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="PostalCode"
                               class="form-label fw-semibold"></label>

                        <input asp-for="PostalCode"
                               class="form-control" />

                        <span asp-validation-for="PostalCode"
                              class="text-danger small"></span>
                    </div>

                    <!-- Password -->
                    <div class="col-md-6 mb-3">

                        <label asp-for="Password"
                               class="form-label fw-semibold"></label>

                        <div class="input-group">
                            <input asp-for="Password"
                                   id="password"
                                   type="password"
                                   class="form-control" />

                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    onclick="togglePassword('password',this)">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>

                        <span asp-validation-for="Password"
                              class="text-danger small"></span>

                    </div>

                    <!-- Confirm Password -->
                    <div class="col-md-6 mb-3">

                        <label asp-for="ConfirmPassword"
                               class="form-label fw-semibold"></label>

                        <div class="input-group">

                            <input asp-for="ConfirmPassword"
                                   id="confirmPassword"
                                   type="password"
                                   class="form-control" />

                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    onclick="togglePassword('confirmPassword',this)">
                                <i class="bi bi-eye"></i>
                            </button>

                        </div>

                        <span asp-validation-for="ConfirmPassword"
                              class="text-danger small"></span>

                    </div>

                    <!-- Role -->
                    <div class="col-md-6 mb-3">

                        <label asp-for="Role"
                               class="form-label fw-semibold"></label>

                        <select asp-for="Role"
                                id="roleSelect"
                                class="form-select">

                            <option value="">Select Role</option>
                            <option value="@Roles.Admin">Admin</option>
                            <option value="@Roles.Employee">Employee</option>
                            <option value="@Roles.Customer">Customer</option>
                            <option value="@Roles.Company">Company</option>

                        </select>

                        <span asp-validation-for="Role"
                              class="text-danger small"></span>

                    </div>

                    <!-- Company -->
                    <div class="col-md-6 mb-3"
                         id="companyContainer"
                         style="display:none;">

                        <label asp-for="CompanyId"
                               class="form-label fw-semibold">
                            Company
                        </label>

                        <select asp-for="CompanyId"
                                asp-items="Model.Companies"
                                class="form-select">

                            <option value="">
                                Select Company
                            </option>

                        </select>

                        <span asp-validation-for="CompanyId"
                              class="text-danger small"></span>

                    </div>

                </div>

                <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-secondary">
                    Cancel
                </a>

                <button type="submit" class="btn btn-success">
                    Create
                </button>
                </div>

            </form>

        </div>

    </div>

</div>

<style>
    .avatar-wrapper {
        display: flex;
        justify-content: center;
    }

    .avatar {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        overflow: hidden;
        cursor: pointer;
        border: 3px solid #dee2e6;
        background: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .avatar-default-icon {
        font-size: 5rem;
        color: #adb5bd;
    }

    .card {
        max-width: 900px;
        margin: auto;
    }
</style>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>

        $(document).ready(function() {

            $('#profileImgInput').on('change', function(e) {

                let file = e.target.files[0];

                if (file) {

                    $('#imagePreview')
                        .attr('src', URL.createObjectURL(file))
                        .show();

                    $('#defaultAvatarIcon').hide();
                    $('#uploadHintText').hide();
                }
            });

            toggleCompany();

            $('#roleSelect').change(function() {
                toggleCompany();
            });
        });

        function toggleCompany() {

            let role = $("#roleSelect").val();

            if (role === "@Roles.Company") {
                $("#companyContainer").slideDown();
            }
            else {
                $("#companyContainer").slideUp();
                $("#CompanyId").val("");
            }
        }

        function togglePassword(id, btn) {

            let input = document.getElementById(id);
            let icon = btn.querySelector("i");

            if (input.type === "password") {
                input.type = "text";
                icon.className = "bi bi-eye-slash";
            }
            else {
                input.type = "password";
                icon.className = "bi bi-eye";
            }
        }

    </script>
}