<div class="container d-flex justify-content-center align-items-center" style="min-height:80vh;">

    <div class="card shadow-lg p-4 text-center" style="max-width:500px; width:100%; border-radius:12px;">

        <p class="text-muted mb-3">
            Email: <strong>@ViewBag.Email</strong>
        </p>

        @if (TempData["success"] != null)
        {
            <div class="text-success mb-3">
                <i class="bi bi-check-circle-fill" style="font-size:50px;"></i>
            </div>

            <h3 class="mb-2">Email Confirmed 🎉</h3>

            <p class="text-muted">
                Your email has been successfully confirmed. You can now login to your account.
            </p>

            <a asp-controller="Auth" asp-action="Login" class="btn btn-success mt-3">
                Go to Login
            </a>
        }
        else
        {
            <div class="text-danger mb-3">
                <i class="bi bi-x-circle-fill" style="font-size:50px;"></i>
            </div>

            <h3 class="mb-2">Confirmation Failed</h3>

            <p class="text-muted">
                The confirmation link is invalid, expired, or already used.
            </p>

            <a asp-controller="Account"
               asp-action="ResendEmailConfirmation"
               asp-route-email="@ViewBag.Email"
               class="btn btn-primary mt-3">
                Resend Email Confirmation
            </a>
        }

    </div>
</div>