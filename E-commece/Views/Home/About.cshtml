<!-- ================= CTA ================= -->

<section class="py-5">

    <div class="container">

        <div class="rounded-4 p-5 text-center text-white"
             style="background:linear-gradient(135deg,#0d6efd,#212529);">

            <h2 class="fw-bold display-5 mb-3">

                Ready To Start Shopping?

            </h2>

            <p class="lead mb-4">

                Discover thousands of quality products with secure checkout,
                fast delivery, and outstanding customer support.

            </p>

            <a asp-controller="Home"
               asp-action="Index"
               class="btn btn-warning btn-lg px-5 fw-bold">

                <i class="bi bi-cart-fill me-2"></i>

                Shop Now

            </a>

        </div>

    </div>

</section>