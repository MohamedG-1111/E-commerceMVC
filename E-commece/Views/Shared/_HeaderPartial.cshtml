<header>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark px-3">
        <div class="container">

            <!-- Brand -->
            <a class="navbar-brand fw-bold"
               asp-controller="Home"
               asp-action="Index">
                <i class="bi bi-bag-heart-fill text-warning me-1"></i>
                E-Commerce
            </a>

            <!-- Toggle -->
            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">

                <!-- Left Links -->
                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Product" asp-action="Index">
                            Products
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Contact">
                            Contact
                        </a>
                    </li>

                </ul>

                <!-- Right Side -->
                <div class="d-flex align-items-center gap-3">

                    <<!-- Cart -->
                        <div class="position-relative">
                            <a asp-controller="Cart"
                               asp-action="Index"
                               class="btn btn-outline-light">
                                <i class="bi bi-cart3"></i>
                            </a>
                            @await Component.InvokeAsync("CartCount")
                        </div>


        

                    <!-- User -->
                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        @await Component.InvokeAsync("UserDropdown")
                    }
                    else
                    {
                        <a asp-controller="Auth"
                           asp-action="Login"
                           class="btn btn-warning btn-sm fw-semibold">
                            Login
                        </a>

                        <a asp-controller="Auth"
                           asp-action="Register"
                           class="btn btn-outline-warning btn-sm fw-semibold">
                            Register
                        </a>
                    }

                </div>

            </div>
        </div>
    </nav>
</header>