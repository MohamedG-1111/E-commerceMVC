@using Ecommerce.Utility.Pagination
@model PaginatedResult<AllAccountsViewModel>

<div class="card-body">

    <table class="table table-hover table-bordered align-middle">

        <thead class="table-dark">
            <tr>
                <th>Full Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th width="260">Actions</th>
            </tr>
        </thead>

        <tbody>

            @if (Model.Items.Any())
            {
                @foreach (var account in Model.Items)
                {
                    <tr id="row-@account.UserId">

                        <td>@account.FullName</td>

                        <td>@account.Email</td>

                        <td>
                            <span class="badge bg-primary">
                                @account.Role
                            </span>
                        </td>

                            <td class="status">
                                @if (account.IsLocked)
                                {
                                    <span class="badge bg-danger">Locked</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                            </td>
                       

                        <td class="d-flex gap-1">

                            <a asp-action="Profile"
                               asp-route-userId="@account.UserId"
                               class="btn btn-info btn-sm">
                                Details
                            </a>

                            <a asp-action="Edit"
                              asp-route-userId="@account.UserId"
                               asp-route-returnUrl="@Url.Action("Index", "Account", new
                               {
                                   pageNumber = Model.PageNumber,
                                   pageSize = Model.PageSize,
                                   search = Context.Request.Query["search"]
                               })" class="btn btn-warning btn-sm">
                                Edit
                            </a>

                            @if (account.IsLocked)
                            {
                                <button class="btn btn-success unlock-btn" data-id="@account.UserId">
                                    Unlock
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-danger lock-btn" data-id="@account.UserId">
                                    Lock
                                </button>
                            }

                            <button class="btn btn-danger btn-sm"
                                    onclick="openDeleteModal('@account.FullName','@account.UserId')">
                                Delete
                            </button>

                        </td>

                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center py-4">
                        No Accounts Found
                    </td>
                </tr>
            }

        </tbody>

    </table>

</div>

<div class="d-flex justify-content-center mt-3">

    <partial name="~/Views/Shared/_PaginationPagePartial.cshtml"
             model="Model" />

</div>