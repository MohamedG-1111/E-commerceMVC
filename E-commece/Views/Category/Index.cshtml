@using DataAcessLayer.Models
@using Ecommerce.Utility.Pagination
@model PaginatedResult<Category>

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<link href="~/css/category/categoryindex.css" rel="stylesheet" />

<div class="admin-wrapper">

    <!-- HEADER -->
    <div class="admin-header">

        <div class="admin-title">
            <i class="bi bi-tags"></i> Category Management
        </div>

        <div class="d-flex gap-2">

            <input type="text"
                   id="searchInput"
                   class="search-box"
                   placeholder="Search categories..." />

            <a asp-controller="Category"
               asp-action="Create"
               class="btn btn-primary">
                + New Category
            </a>

        </div>

    </div>

    <!-- CONTENT -->
    <div class="card">

        <div id="categoryTableContainer">
            <partial name="_CategoryPartial" model="Model" />
        </div>

    </div>

</div>

<!-- DELETE MODAL -->
<div id="deleteOverlay"
     onclick="handleOverlayClick(event)">

    <div class="modal-box">

        <i class="bi bi-trash" style="font-size:40px;color:#dc3545;"></i>

        <h5 class="mt-2">Confirm Delete</h5>

        <p class="text-muted">
            Delete <strong id="categoryName"></strong> ?
        </p>

        <div class="d-flex justify-content-center gap-2">

            <button class="btn btn-secondary btn-sm"
                    onclick="closeDeleteModal()">
                Cancel
            </button>

            <a id="confirmDeleteBtn"
               class="btn btn-danger btn-sm">
                Delete
            </a>

        </div>

    </div>

</div>

<!-- SCRIPT -->
@section Scripts
{
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>

        $(document).ready(function() {

            $("#searchInput").on("keyup", function() {
                loadCategories();
            });

        });

        function loadCategories(page = 1) {

            $.ajax({
                url: "/Category/Search",
                type: "GET",
                data: {
                    searchTerm: $("#searchInput").val(),
                    pageNumber: page,
                    pageSize: @Model.PageSize
                },
                success: function(result) {
                    $("#categoryTableContainer").html(result);
                },
                error: function(xhr) {
                    console.log(xhr.responseText);
                }
            });
        }

        // Search
        $("#searchInput").on("keyup", function() {
            loadCategories();
        });

        // Pagination
        $(document).on("click", ".pagination-link", function(e) {

            e.preventDefault();

            let page = $(this).data("page");

            loadCategories(page);
        });

        function openDeleteModal(name, url) {
            $("#categoryName").text(name);
            $("#confirmDeleteBtn").attr("href", url);
            $("#deleteOverlay").css("display", "flex");
        }

        function closeDeleteModal() {
            $("#deleteOverlay").hide();
        }

        function handleOverlayClick(e) {
            if (e.target.id === "deleteOverlay") {
                closeDeleteModal();
            }
        }

        document.addEventListener("keydown", function(e) {
            if (e.key === "Escape") closeDeleteModal();
        });

    </script>
}