@model BLL.ViewModels.CategoryVM

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">

            <div class="card border-0 shadow-sm">
                <div class="card-header border-0 py-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-tag-fill text-warning me-2"></i>
                        Create Category
                    </h5>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Edit" asp-controller="Category" method="post">

                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">
                                Name <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Name"
                                   class="form-control"
                                   placeholder="e.g. Electronics"
                                   autofocus />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="DisplayOrder" class="form-label fw-semibold">
                                Display Order <span class="text-danger">*</span>
                            </label>
                            <input asp-for="DisplayOrder"
                                   class="form-control"
                                   type="number"
                                   min="1"
                                   placeholder="e.g. 1" />
                            <span asp-validation-for="DisplayOrder" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-controller="Category" asp-action="Index"
                                   class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg me-1"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-warning fw-semibold">
                                <i class="bi bi-plus-lg me-1"></i>Create
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>

}