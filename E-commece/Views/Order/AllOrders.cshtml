@using E_commerce.DAL.Entities.enums
@using Ecommerce.Utility
@using Ecommerce.Utility.Pagination
@model PaginatedResult<OrderVM>

@{
    ViewData["Title"] = "Orders";
}

<div class="container my-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">My Orders</h2>
            <p class="text-muted small mb-0">
                Manage and track your recent purchase history.
            </p>
        </div>
    </div>

    @if (Model == null || !Model.Items.Any())
    {
        <div class="card border-0 shadow-sm text-center p-5">
            <div class="card-body">
                <i class="bi bi-receipt-cutoff display-3 text-muted"></i>

                <h4 class="fw-semibold mt-3">
                    No Orders Found
                </h4>

                <p class="text-muted">
                    You haven't placed any orders yet.
                </p>

                <a asp-controller="Home"
                   asp-action="Index"
                   class="btn btn-primary">
                    Start Shopping
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">

                <div class="row g-3 align-items-end">

                    <div class="col-lg-3">
                        <select id="status"
                                class="form-select"
                                asp-items="Html.GetEnumSelectList<OrderStatus>()">
                            <option value="">All Statuses</option>
                        </select>
                    </div>

                    <div class="col-lg-3">
                        <select id="payment"
                                class="form-select"
                                asp-items="Html.GetEnumSelectList<PaymentStatus>()">
                            <option value="">All Payments</option>
                        </select>
                    </div>

                    <div class="col-lg-2">
                        <label for="from" class="form-label">From</label>
                        <input type="date"
                               id="from"
                               class="form-control" />
                    </div>

                    <div class="col-lg-2">
                        <label for="to" class="form-label">To</label>
                        <input type="date"
                               id="to"
                               class="form-control" />
                    </div>
                    @if (User.IsInRole(Roles.Admin))
                    {
                        <input id="email" class="form-control" placeholder="Search by email" />
                    }
                    <div class="col-lg-2 d-grid">
                        <button type="button"
                                id="clearFilter"
                                class="btn btn-outline-secondary">
                            Clear
                        </button>
                    </div>

                </div>

            </div>
        </div>

        <div id="orders-container">
            <partial name="_MyOrderPartial" model="Model" />
        </div>
    }

</div>

@section Scripts
{
    <script>

        function loadOrders(page = 1) {

            $.ajax({
                url: "/Order/FilterOrders",
                type: "GET",
                data: {
                    PageNumber: page,
                    Status: $("#status").val(),
                    PaymentStatus: $("#payment").val(),
                    From: $("#from").val(),
                    To: $("#to").val(),
                    Email: $("#email").val()
                },
                success: function(result) {
                    $("#orders-container").html(result);
                }
            });

        }

        // Pagination
        $(document).on("click", ".pagination-link", function(e) {
            e.preventDefault();

            loadOrders($(this).data("page"));
        });

        // Filters
        $("#status, #payment, #from, #to").on("change", function () {
    loadOrders();
});

$("#email").on("input", function () {
    loadOrders();
});

        // Clear Filters
        $("#clearFilter").on("click", function() {

            $("#status").val("");
            $("#payment").val("");
            $("#from").val("");
            $("#to").val("");
            $("#email").val("");

            loadOrders();
        });

    </script>
}