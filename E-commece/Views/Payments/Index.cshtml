@using E_commerce.Utility.Settings
@using Ecommerce.Utility
@model CustomerCart

@{
    ViewData["Title"] = "Payment";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

@if (User.IsInRole(Roles.Customer))
{
    <script src="https://js.stripe.com/v3/"></script>
}

<div class="container py-5">

    <div class="row">

        <!-- Payment -->
        <div class="col-lg-8">

            <div class="card shadow-sm border-0 rounded-4">

                <div class="card-header bg-white py-3">
                    <h4 class="mb-0">
                        <i class="bi bi-credit-card"></i>
                        Payment
                    </h4>
                </div>

                <div class="card-body">

                    @if (User.IsInRole(Roles.Customer))
                    {
                        <form id="payment-form">

                            @Html.AntiForgeryToken()

                            <div id="payment-element"></div>

                            <button id="submit"
                                    class="btn btn-success mt-4 w-100">
                                Pay $@Model.Total
                            </button>

                            <div id="error-message"
                                 class="text-danger mt-3"></div>

                        </form>
                    }
                    else if (User.IsInRole(Roles.Company))
                    {
                        <form asp-action="PlaceOrder"
                              asp-controller="Order"
                              method="post">

                            @Html.AntiForgeryToken()

                            <div class="alert alert-info">
                                <i class="bi bi-info-circle"></i>
                                As a company account, you can place your order now and complete the payment later.
                            </div>

                            <button type="submit"
                                    class="btn btn-primary w-100">
                                Place Order
                            </button>

                        </form>
                    }

                </div>

            </div>

        </div>

        <!-- Order Summary -->
        <div class="col-lg-4">

            <div class="card shadow-sm border-0 rounded-4">

                <div class="card-header bg-white">
                    <h4>Order Summary</h4>
                </div>

                <div class="card-body">

                    @foreach (var item in Model.Items)
                    {
                        <div class="d-flex mb-3">

                            <img src="@($"{FileSettings.ImagesPathProducts}/{item.Image}")"
                                 width="70"
                                 height="70"
                                 class="rounded" />

                            <div class="ms-3 flex-grow-1">

                                <h6>@item.Name</h6>

                                <small>Qty : @item.Count</small>

                            </div>

                            <strong>
                                $@((item.Price * item.Count).ToString("0.00"))
                            </strong>

                        </div>
                    }

                    <hr />

                    <div class="d-flex justify-content-between">
                        <span>Discount</span>
                        <strong>$@Model.Discount</strong>
                    </div>

                    <div class="d-flex justify-content-between">
                        <span>Total</span>
                        <strong>$@Model.Total</strong>
                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

@if (User.IsInRole(Roles.Customer))
{
    @section Scripts
    {
        <script>

            const stripe = Stripe("pk_test_51TogX1HdvlOk3mpffT5ldPJ6h2As18w6yWvHhQeL1k6rVnCkmOnSLFzmI4sVBlg3lU8A5v2lZE0MgqfbV36f9mPv00Swh2T6Zp");

            const clientSecret = '@Model.ClientSecret';

            const elements = stripe.elements({
                clientSecret: clientSecret
            });

            const paymentElement = elements.create("payment");

            paymentElement.mount("#payment-element");

                $("#payment-form").submit(async function (e) {

                    e.preventDefault();

                    $("#submit").prop("disabled", true);
                $("#error-message").text("");

                    var token = $('input[name="__RequestVerificationToken"]').val();

                    $.ajax({

                    url: "/Order/PlaceOrder",

                    type: "POST",

                    headers: {
                            RequestVerificationToken: token
                    },

                    success: async function () {

                    const { error } = await stripe.confirmPayment({

                        elements,

                        confirmParams: {

                            return_url: "@Url.Action("Success", "Payments", null, Context.Request.Scheme)"

                        }

                    });

                    if (error) {

                        $("#error-message").text(error.message);

                        $("#submit").prop("disabled", false);
                            }
                },

                error: function (xhr) {

                    $("#error-message").text(
                                xhr.responseJSON?.message ?? "Failed to create order."
                    );

                            $("#submit").prop("disabled", false);
                    }

                });

                });

        </script>
    }
}