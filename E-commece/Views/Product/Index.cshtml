@using BLL.ViewModels
@using E_commerce.Utility.Settings
@model IEnumerable<ProductListVm>

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="~/css/product/producttableindex.css" rel="stylesheet" />
<div class="admin-wrapper">

    <!-- HEADER -->
    <div class="admin-header">

        <div class="admin-title">
            <i class="bi bi-box-seam"></i> Products Management
        </div>

        <div class="admin-search">

            <input type="text"
                   id="searchInput"
                   placeholder="Search products..." />

            <select id="categoryFilter">

                <option value="">All Categories</option>

                @foreach (var cat in Model.Select(p => p.CategoryName)
                                          .Where(c => !string.IsNullOrEmpty(c))
                                          .Distinct()
                                          .OrderBy(c => c))
                {
                    <option value="@cat">@cat</option>
                }

            </select>

            <a asp-controller="Product"
               asp-action="Create"
               class="btn btn-primary">
                + Add
            </a>

        </div>

    </div>

    <!-- TABLE -->
    <div class="card">

        <div id="productsTableContainer">
            <partial name="~/Views/Product/_ProductTablePartial.cshtml"
                     model="Model" />
        </div>

    </div>

</div>

<!-- DELETE MODAL -->
<div id="deleteOverlay"
     onclick="handleOverlayClick(event)">

    <div class="modal-box">

        <i class="bi bi-trash" style="font-size:40px;color:#dc3545;"></i>

        <h5 class="mt-2">Confirm Delete</h5>

        <p class="text-muted">
            Delete <strong id="productName"></strong> ?
        </p>

        <div class="d-flex justify-content-center gap-2">

            <button class="btn btn-secondary btn-sm"
                    onclick="closeDeleteModal()">
                Cancel
            </button>

            <a id="confirmDeleteBtn"
               class="btn btn-danger btn-sm">
                Delete
            </a>

        </div>

    </div>

</div>

<!-- SCRIPT -->
@section Scripts
{
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

    $(document).ready(function () {

        $("#searchInput").on("keyup", function () {
            loadProducts();
        });

        $("#categoryFilter").on("change", function () {
            loadProducts();
        });

    });

    function loadProducts() {

        $.ajax({
            url: "/Product/SearchTable",
            type: "GET",
            data: {
                searchTerm: $("#searchInput").val(),
                category: $("#categoryFilter").val()
            },
            success: function (result) {
                $("#productsTableContainer").html(result);
            }
        });

    }

    function openDeleteModal(name, url) {
        $("#productName").text(name);
        $("#confirmDeleteBtn").attr("href", url);
        $("#deleteOverlay").css("display", "flex");
    }

    function closeDeleteModal() {
        $("#deleteOverlay").hide();
    }

    function handleOverlayClick(e) {
        if (e.target.id === "deleteOverlay") {
            closeDeleteModal();
        }
    }

</script>
}