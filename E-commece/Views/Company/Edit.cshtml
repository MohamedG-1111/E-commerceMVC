@model CompanyInfoVM

@{
    ViewData["Title"] = "Edit Company";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">

            <div class="card border-0 shadow-sm">

                <div class="card-header border-0 py-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-building-gear text-primary me-2"></i>
                        Edit Company
                    </h5>
                </div>

                <div class="card-body p-4">

                    <form asp-action="Edit" asp-controller="Company" method="post">

                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <!-- Name -->
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <!-- Email -->
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <!-- City -->
                        <div class="mb-3">
                            <label asp-for="City" class="form-label fw-semibold"></label>
                            <input asp-for="City" class="form-control" />
                            <span asp-validation-for="City" class="text-danger small"></span>
                        </div>

                        <!-- Postal Code -->
                        <div class="mb-3">
                            <label asp-for="PostalCode" class="form-label fw-semibold"></label>
                            <input asp-for="PostalCode" class="form-control" />
                            <span asp-validation-for="PostalCode" class="text-danger small"></span>
                        </div>
                        <!-- Phone -->
                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label fw-semibold"></label>
                            <input asp-for="Phone" class="form-control" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <!-- Address -->
                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-semibold"></label>
                            <input asp-for="Address" class="form-control" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <!-- Discount -->
                        <div class="mb-4">
                            <label asp-for="DiscountPercentage" class="form-label fw-semibold"></label>

                            <div class="input-group">
                                <input asp-for="DiscountPercentage"
                                       class="form-control"
                                       type="number"
                                       min="0"
                                       max="100" />
                                <span class="input-group-text">%</span>
                            </div>

                            <span asp-validation-for="DiscountPercentage" class="text-danger small"></span>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex gap-2 justify-content-end">

                            <a asp-controller="Company"
                               asp-action="Index"
                               class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg me-1"></i>
                                Cancel
                            </a>

                            <button type="submit" class="btn btn-primary fw-semibold">
                                <i class="bi bi-save me-1"></i>
                                Update
                            </button>

                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}