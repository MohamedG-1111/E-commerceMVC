@using E_commerce.BLL.Settings
@using E_commerce.DAL.Entities

@model Product

@{
    ViewData["Title"] = "Delete Product";
}

<div class="delete-wrapper">
    <div class="delete-card">

        <!-- Header -->
        <div class="delete-header">
            <i class="bi bi-trash3-fill"></i>
            <span>Delete Product</span>
        </div>

        <div class="delete-body">

            <!-- Warning -->
            <div class="delete-alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <p>
                    Are you sure you want to delete this product?
                    This action <strong>cannot be undone.</strong>
                </p>
            </div>

            <!-- Product Preview -->
            <div class="product-preview">

                <!-- Image -->
                <div class="product-image-section">

                    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                    {
                        <img asp-append-version="true"
                             src="~/@FileSettings.ImagesPath/@Model.ImageUrl"
                             alt="@Model.Title"
                             class="product-image" />
                    }
                    else
                    {
                        <div class="product-image-placeholder">
                            <i class="bi bi-image"></i>
                        </div>
                    }

                </div>

                <!-- Details -->
                <div class="product-details">

                    <div class="detail-row">
                        <span class="detail-label">Title</span>
                        <h4 class="product-title">@Model.Title</h4>
                    </div>

                    <div class="description-text">
                        <span class="detail-label">Description</span>

                        @Html.Raw(Model.Description)
                    </div>

                    <div class="detail-row">
                        <span class="detail-label">Category</span>
                        <span class="badge-category">
                            @Model.Category?.Name
                        </span>
                    </div>

                    <div class="detail-row">
                        <span class="detail-label">ISBN</span>
                        <span class="detail-value">
                            @Model.ISBN
                        </span>
                    </div>

                    <div class="price-grid">

                        <div class="detail-row price-card">
                            <span class="detail-label">List Price</span>
                            <span class="price-value">
                                $@Model.ListPrice
                            </span>
                        </div>

                       

                    </div>

                </div>
            </div>

            <!-- Buttons -->
            <div class="action-buttons">

                <a asp-action="Index" class="btn-cancel">
                    <i class="bi bi-x-lg"></i>
                    Cancel
                </a>

                <form asp-action="DeleteConfirmed" method="post">

                    <input asp-for="Id" type="hidden" />

                    <button type="submit" class="btn-delete">
                        <i class="bi bi-trash3-fill"></i>
                        Yes, Delete
                    </button>
                </form>

            </div>

        </div>
    </div>
</div>

<style>

    .delete-wrapper {
        display: flex;
        justify-content: center;
        padding: 2rem 1rem;
    }

    .delete-card {
        width: 100%;
        max-width: 950px;
        background: #fff;
        border-radius: 16px;
        border: 1px solid #f1d4d4;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,.06);
        transition: .3s;
    }

        .delete-card:hover {
            box-shadow: 0 16px 40px rgba(0,0,0,.08);
        }

    /* Header */

    .delete-header {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: 1.25rem 1.5rem;
        background: #fef2f2;
        border-bottom: 1px solid #fecaca;
        color: #b91c1c;
        font-size: 1.2rem;
        font-weight: 700;
    }

        .delete-header i {
            font-size: 1.35rem;
        }

    /* Body */

    .delete-body {
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* Alert */

    .delete-alert {
        display: flex;
        gap: .75rem;
        align-items: flex-start;
        padding: 1rem 1.2rem;
        border-radius: 10px;
        border: 1px solid #fca5a5;
        background: #fff5f5;
        color: #7f1d1d;
    }

        .delete-alert i {
            color: #dc2626;
            font-size: 1.1rem;
            margin-top: 2px;
        }

        .delete-alert p {
            margin: 0;
            line-height: 1.5;
        }

    /* Product Card */

    .product-preview {
        display: flex;
        align-items: center;
        gap: 2rem;
        padding: 1.5rem;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        background: #fff;
    }

    /* Image */

    .product-image-section {
        flex-shrink: 0;
    }

    .product-image,
    .product-image-placeholder {
        width: 180px;
        height: 240px;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        background: #f3f4f6;
    }

    .product-image {
        object-fit: cover;
    }

    .product-image-placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: #9ca3af;
    }

    /* Details */

    .product-details {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .detail-row {
        display: flex;
        flex-direction: column;
        gap: .3rem;
    }

    .detail-label {
        font-size: .75rem;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: #9ca3af;
        font-weight: 700;
    }

    .product-title {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
    }

    .detail-value {
        color: #374151;
        font-size: .95rem;
    }

    .description-text {
        padding: .9rem;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        color: #4b5563;
        line-height: 1.6;
    }

    .badge-category {
        display: inline-flex;
        align-self: flex-start;
        padding: .35rem 1rem;
        border-radius: 999px;
        background: #fff1f2;
        border: 1px solid #fca5a5;
        color: #b91c1c;
        font-size: .85rem;
        font-weight: 600;
    }

    /* Price Cards */

    .price-grid {
        display: grid;
        grid-template-columns: repeat(2,minmax(140px,1fr));
        gap: 1rem;
    }

    .price-card {
        padding: .9rem;
        border-radius: 10px;
        border: 1px solid #fecaca;
        background: #fff5f5;
    }

    .price-value {
        color: #dc2626;
        font-size: 1.1rem;
        font-weight: 700;
    }

    /* Buttons */

    .action-buttons {
        display: flex;
        justify-content: flex-end;
        gap: .75rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e5e7eb;
    }

        .action-buttons form {
            margin: 0;
        }

    .btn-cancel,
    .btn-delete {
        min-width: 160px;
        height: 48px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        font-weight: 600;
        text-decoration: none;
        transition: .2s;
    }

    .btn-cancel {
        background: #fff;
        border: 1px solid #d1d5db;
        color: #374151;
    }

        .btn-cancel:hover {
            background: #f9fafb;
            color: #111827;
        }

    .btn-delete {
        border: none;
        color: white;
        background: linear-gradient(135deg,#dc2626,#b91c1c);
        box-shadow: 0 4px 12px rgba(220,38,38,.25);
    }

        .btn-delete:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(220,38,38,.35);
        }

    /* Mobile */

    @@media (max-width: 768px) {

        .product-preview {
            flex-direction: column;
            align-items: stretch;
        }

        .product-image,
        .product-image-placeholder {
            width: 100%;
            height: 280px;
        }

        .price-grid {
            grid-template-columns: 1fr;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn-cancel,
        .btn-delete {
            width: 100%;
        }
    }

</style>